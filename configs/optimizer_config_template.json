{
  "search_space": {
    "chunking": {
      "size": [
        128,
        256,
        512
      ],
      "overlap": [
        0,
        32,
        64
      ],
      "strategy": [
        "token",
        "sentence",
        "semantic"
      ]
    },
    "indexing": {
      "retriever": [
        "bm25",
        "dense",
        "hybrid"
      ],
      "embedding_model": [
        "sentence-transformers/all-MiniLM-L6-v2",
        "BAAI/bge-base-en"
      ],
      "metadata_enrichment": [
        false
      ]
    },
    "reranking": {
      "enabled": [
        false,
        true
      ],
      "model": [
        "cross-encoder/ms-marco-MiniLM-L-6-v2",
        "BAAI/bge-reranker-base"
      ]
    },
    "generation": {
      "llm": [
        "zhipu-glm4-flash"
      ],
      "temperature": [
        0.0,
        0.2
      ],
      "answer_style": [
        "concise",
        "citation_first"
      ]
    },
    "query_refinement": {
      "rewrite": [
        false,
        true
      ],
      "decompose": [
        false,
        true
      ]
    }
  },
  "objective": {
    "case1_primary_metrics": [
      "context_recall",
      "answer_similarity",
      "faithfulness"
    ],
    "case2_primary_metrics": [
      "retrieval_coverage_proxy",
      "groundedness",
      "citation_quality"
    ]
  },

   "model_registry": {
    "zhipu-glm4-flash": {
      "provider": "zhipu",
      "api_key_env": "ZHIPU_API_KEY",
      "api_base_env": "ZHIPU_API_BASE",
      "api_base_default": "https://open.bigmodel.cn/api/paas/v4/",
      "model_name_env": "ZHIPU_MODEL",
      "model_name_default": "glm-4-flash"
    },
    "local-instruct": {
      "provider": "local",
      "api_base_env": "LOCAL_LLM_BASE",
      "api_base_default": "http://localhost:8000/v1",
      "model_name_env": "LOCAL_LLM_MODEL",
      "model_name_default": "local-instruct"
    }
  }
}